GOOGLE_API_KEY=your_key_from_https://aistudio.google.com/app/apikey
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DBNAME
# Signing secret for refresh-survival session tokens. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# MUST be set in production — without it, the public dev fallback is used and
# tokens could be forged. Keep this value secret; never commit the real one.
SESSION_SECRET=generate_with_secrets.token_urlsafe_48

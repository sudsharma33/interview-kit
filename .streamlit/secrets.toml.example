# Local dev only. Copy this file to .streamlit/secrets.toml and fill in your
# real values. The real secrets.toml is gitignored and never committed.
#
# In production (Streamlit Cloud), these same values live in the hosted
# "Secrets" panel — same TOML format, different location.

# === LLM + database ===
# (For local runs, .env still works for these. secrets.toml is required only
# for the [auth] section because Streamlit reads it before .env in the boot
# sequence for OIDC.)
GOOGLE_API_KEY = "AIza..."
DATABASE_URL   = "postgresql+psycopg://USER:PASS@HOST:5432/DBNAME"

# === Microsoft SSO (OpenID Connect) ===
[auth]
# For local dev, the redirect URI must be http://localhost:8501/oauth2callback
# and that URI must be registered in your Azure app registration too.
redirect_uri        = "http://localhost:8501/oauth2callback"

# A random 64-char hex string. Used to sign the auth cookie. Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
cookie_secret       = "REPLACE_WITH_A_64_CHAR_HEX_STRING"

# From Azure Portal → App registrations → your app → Overview
client_id           = "59c3b90e-d200-4c50-976d-080fcaabb3a6"

# From Azure Portal → App registrations → your app → Certificates & secrets
# (the Value column, only shown once at creation)
client_secret       = "REPLACE_WITH_AZURE_CLIENT_SECRET"

# `common` for multi-tenant + personal Microsoft accounts.
# Use your tenant ID instead if you want to restrict to a single org.
server_metadata_url = "https://login.microsoftonline.com/common/v2.0/.well-known/openid-configuration"
